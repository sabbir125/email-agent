OPENAI_API_KEY=sk-...
DATABASE_URL=sqlite:///./data/emails.db
SCHEDULER_INTERVAL_MINUTES=2
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT=30

# ─── Email Source ─────────────────────────────────────────────────────────────
# "mock" reads from mock_data/emails.json
# "gmail" connects via IMAP
EMAIL_SOURCE=mock

# ─── Mock Data (used when EMAIL_SOURCE=mock) ──────────────────────────────────
MOCK_DATA_PATH=mock_data/emails.json

# ─── Gmail IMAP (required when EMAIL_SOURCE=gmail) ───────────────────────────
# Generate an App Password at: https://myaccount.google.com/apppasswords
# IMAP must be enabled at: Gmail Settings → See all settings → Forwarding and POP/IMAP
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GMAIL_MAX_EMAILS=20
GMAIL_FOLDER=INBOX
